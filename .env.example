# Images
FESS_IMAGE=ghcr.io/codelibs/fess:15.7.0-noble
OPENSEARCH_IMAGE=ghcr.io/codelibs/fess-opensearch:3.7.0
NGINX_IMAGE=nginx:alpine
ALPINE_IMAGE=alpine:3.21

# Plugin
FESS_PLUGINS=fess-webapp-multimodal:15.7.0

# CLIP model (keep MODEL and DIMENSION in lockstep)
CLIP_MODEL_NAME=xlm-roberta-base-ViT-B-32::laion5b-s13b-b90k
MULTIMODAL_DIMENSION=512
CLIP_MIN_SCORE=0.56
# Default search results per page (mosaic gallery honors page_size_default)
SEARCH_PAGE_SIZE=20

# Embedding server device: cpu | cuda | auto
CLIP_DEVICE=cpu

# Theme
THEME_NAME=mosaic
FESS_THEMES_REPO=https://github.com/codelibs/fess-themes.git
FESS_THEMES_REF=main
# FESS_THEMES_DIR=/absolute/path/to/local/fess-themes   # dev: use a local checkout instead of cloning

# Resources
FESS_HEAP=1g
OPENSEARCH_HEAP=1g
OPENSEARCH_HEAP_PROD=3g

# Ops
FESS_ADMIN_PASSWORD=admin
MAX_WAIT=900
DOMAIN=multimodal.codelibs.org
CLIP_SERVER_IMAGE=docker-multimodalsearch/clip-server:local

# clip_server runs as a non-root user; bin/setup.sh auto-fills these with the
# host user's UID/GID so the bind-mounted model cache stays writable. Uncomment
# to pin explicit values instead.
# CLIP_UID=1000
# CLIP_GID=1000
# Pillow decode cap for untrusted images (oversized / decompression-bomb -> HTTP 400)
CLIP_MAX_IMAGE_PIXELS=64000000
